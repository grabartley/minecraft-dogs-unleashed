{
  "schemaVersion": 1,
  "id": "dogs-unleashed",
  "version": "${version}",
  "name": "Dogs Unleashed",
  "description": "Adds new dog breeds and dog-related items to enhance the player's experience with their canine companions.",
  "authors": [
    "Vitória Vedana",
    "Graham Bartley"
  ],
  "contact": {
    "homepage": "https://grahambartley.com/",
    "sources": "https://github.com/grabartley/minecraft-dogs-unleashed"
  },
  "license": "CC0-1.0",
  "icon": "assets/dogs-unleashed/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.grahambartley.DogsUnleashed"
    ],
    "client": [
      "com.grahambartley.DogsUnleashedClient"
    ],
    "fabric-datagen": [
      "com.grahambartley.DogsUnleashedDataGenerator"
    ],
    "fabric-gametest": [
      "com.grahambartley.gametest.HuskyEntityGameTest",
      "com.grahambartley.gametest.DachshundEntityGameTest",
      "com.grahambartley.gametest.BeagleEntityGameTest",
      "com.grahambartley.gametest.GoldenRetrieverEntityGameTest",
      "com.grahambartley.gametest.ShibaInuEntityGameTest",
      "com.grahambartley.gametest.UnleashedDogEntityGameTest",
      "com.grahambartley.gametest.DogBedBlockGameTest",
      "com.grahambartley.gametest.DogSleepBehaviorGameTest"
    ]
  },
  "mixins": [
    "dogs-unleashed.mixins.json",
    {
      "config": "dogs-unleashed.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.16.5",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": ">=0.107.0+1.21.1",
    "geckolib": ">=4.7"
  },
  "suggests": {
    "another-mod": "*"
  }
}
